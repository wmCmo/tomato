{
    "extends": [
        "stylelint-config-standard"
    ],
    "rules": {
        "at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": [
                    "theme",
                    "custom-variant",
                    "apply",
                    "utility",
                    "source",
                    "variant"
                ]
            }
        ]
    }
}